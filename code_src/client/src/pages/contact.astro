---
import BaseLayout from '../layouts/BaseLayout.astro'
---
<BaseLayout title="联系｜个人星球"><section class="contact page-contact"><div><p class="eyebrow">SAY HELLO</p><h2>有一个有趣的想法？<br /><span>来信聊聊。</span></h2><div class="contact-links"><a href="mailto:hello@example.com">✉ hello@example.com</a><a href="https://github.com">◈ GitHub</a></div></div><form><label>你的称呼<input required name="name" placeholder="怎么称呼你？" /></label><label>联系邮箱<input required type="email" name="email" placeholder="name@example.com" /></label><label>想说的话<textarea required name="message" rows="4" placeholder="写下你的想法吧…"></textarea></label><button class="primary-button" type="submit">发送消息 ↗</button></form></section></BaseLayout>
