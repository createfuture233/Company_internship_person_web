---
/**
 * 联系页面
 * 提供联系方式展示和联系表单
 */
import BaseLayout from '../layouts/BaseLayout.astro'    // 基础布局
import ContactForm from '../components/ContactForm'      // 联系表单组件

// API配置
const apiBase = import.meta.env.PUBLIC_API_BASE ?? 'http://localhost:3000/api'

// 默认设置（当后端不可用时使用）
const fallbackSettings = {
  contact_email: 'hello@example.com',
  github_url: 'https://github.com',
}

// 站点设置（SSR期间获取）
let settings = fallbackSettings

try {
  const response = await fetch(`${apiBase}/settings`)
  if (response.ok) {
    const data = await response.json()
    settings = {
      contact_email: data.contact_email?.trim() || fallbackSettings.contact_email,
      github_url: data.github_url?.trim() || fallbackSettings.github_url,
    }
  }
} catch {
  settings = fallbackSettings
}

// 格式化邮箱链接
const emailHref = settings.contact_email.startsWith('mailto:')
  ? settings.contact_email
  : `mailto:${settings.contact_email}`
---

<BaseLayout title="联系｜B-612星球">
  <section class="contact page-contact">
    <div>
      <p class="eyebrow">SAY HELLO</p>
      <h2>有一个有趣的想法？<br /><span>来信聊聊。</span></h2>
      <div class="contact-links">
        <a href={emailHref}>✉ {settings.contact_email.replace(/^mailto:/, '')}</a>
        <a href={settings.github_url} target="_blank" rel="noreferrer">◇ GitHub</a>
      </div>
    </div>
    <ContactForm client:load />
  </section>
</BaseLayout>