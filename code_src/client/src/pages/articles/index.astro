---
/**
 * 文章列表页面
 * 展示所有文章，支持分页浏览
 */
import BaseLayout from "../../layouts/BaseLayout.astro";      // 基础布局
import ProximityHeading from "../../components/ProximityHeading"; // 邻近效应标题
import { apiBase } from "../../lib/api";                        // API配置
import { resolveCover } from "../../lib/defaultCovers";        // 封面解析工具

/** 文章类型 */
type Article = {
  id: string;                     // 文章ID
  title: string;                  // 标题
  summary: string;                // 摘要
  coverUrl: string | null;        // 封面图片URL
  publishedAt: string | null;     // 发布时间
  tags: Array<{ name: string }>;  // 标签列表
};

// 数据初始化
let articles: Article[] = [];  // 文章列表
let loadError = false;         // 加载错误标志

// SSR期间获取文章数据
try {
  const response = await fetch(`${apiBase}/articles`);
  if (!response.ok) throw new Error("Unable to load articles");
  articles = await response.json();
} catch {
  loadError = true;
}

/**
 * 格式化日期为中文格式
 * @param value - ISO日期字符串
 * @returns 格式化的日期
 */
const formatDate = (value: string | null) =>
  value
    ? new Intl.DateTimeFormat("zh-CN", { dateStyle: "medium" }).format(
        new Date(value),
      )
    : "持续更新";

// 分页配置
const pageSize = 9;                                                                 // 每页条数
const requestedPage = Number(Astro.url.searchParams.get("page") ?? "1");             // 请求的页码
const totalPages = Math.max(1, Math.ceil(articles.length / pageSize));              // 总页数
const currentPage = Number.isFinite(requestedPage) ? Math.min(Math.max(1, Math.trunc(requestedPage)), totalPages) : 1; // 当前页码（安全处理）
const pagedArticles = articles.slice((currentPage - 1) * pageSize, currentPage * pageSize); // 当前页文章
const pageNumbers = Array.from({ length: totalPages }, (_, index) => index + 1);    // 页码数组
---

<BaseLayout title="文章｜B-612星球">
  <section class="section standalone-page">
    <div class="section-heading">
      <div>
        <p class="eyebrow">WRITING</p>
        <h2><ProximityHeading client:load label="最近的记录" /></h2>
      </div>
    </div>

    {
      loadError ? (
        <p class="empty">文章暂时无法加载，请确认后端服务已经启动。</p>
      ) : articles.length ? (
        <>
          <div class="article-grid">
            {pagedArticles.map((article, index) => {
              const coverIndex = (currentPage - 1) * pageSize + index;
              return (
                <article class="article-card">
                  <img
                    class="content-cover-thumb"
                    src={resolveCover("article", article.coverUrl, coverIndex)}
                    alt={`${article.title} 封面图`}
                    loading="lazy"
                  />
                  <p class="meta">
                    {formatDate(article.publishedAt)} · {article.tags[0]?.name ?? "文章"}
                  </p>
                  <h3>{article.title}</h3>
                  <p>{article.summary}</p>
                  <a class="text-button reveal-link" href={`/articles/${article.id}`}>
                    阅读文章 ↗
                  </a>
                </article>
              );
            })}
          </div>
          {totalPages > 1 && (
            <nav class="pagination" aria-label="文章分页">
              <a class={currentPage === 1 ? "disabled" : ""} href={currentPage === 1 ? undefined : "/articles?page=1"}>第一页</a>
              <a class={currentPage === 1 ? "disabled" : ""} href={currentPage === 1 ? undefined : `/articles?page=${currentPage - 1}`}>上一页</a>
              {pageNumbers.map((page) => (
                <a class={page === currentPage ? "active" : ""} href={`/articles?page=${page}`} aria-current={page === currentPage ? "page" : undefined}>
                  {page}
                </a>
              ))}
              <a class={currentPage === totalPages ? "disabled" : ""} href={currentPage === totalPages ? undefined : `/articles?page=${currentPage + 1}`}>下一页</a>
              <a class={currentPage === totalPages ? "disabled" : ""} href={currentPage === totalPages ? undefined : `/articles?page=${totalPages}`}>最后一页</a>
            </nav>
          )}
        </>
      ) : (
        <p class="empty">暂时还没有已发布的文章。</p>
      )
    }

    <div class="detail-block">
      <p class="eyebrow">TOPICS I FOLLOW</p>
      <div class="topic-grid">
        <span>前端工程化</span>
        <span>交互与动效</span>
        <span>产品思考</span>
        <span>个人成长</span>
        <span>设计灵感</span>
        <span>AI 协作</span>
      </div>
    </div>
  </section>
</BaseLayout>