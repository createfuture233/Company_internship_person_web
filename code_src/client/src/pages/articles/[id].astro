---
/**
 * 文章详情页面
 * 根据文章ID展示单篇文章的详细内容
 * @note 禁用预渲染，因为需要动态获取文章内容
 */
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";      // 基础布局
import Comments from "../../components/Comments";              // 评论组件
import AdminDetailEdit from "../../components/AdminDetailEdit"; // 管理员编辑入口
import MarkdownRenderer from "../../components/MarkdownRenderer"; // Markdown渲染器
import { apiBase } from "../../lib/api";                        // API配置
import { resolveCover } from "../../lib/defaultCovers";        // 封面解析工具

// 获取URL参数中的文章ID
const { id } = Astro.params;

// SSR期间获取文章数据
const response = id
  ? await fetch(`${apiBase}/content/article/${encodeURIComponent(id)}`)
  : null;

// 如果文章不存在或获取失败，重定向到文章列表
if (!response?.ok) return Astro.redirect("/articles");

// 解析文章数据
const article = (await response.json()) as {
  id: string;                     // 文章ID
  title: string;                  // 标题
  summary: string;                // 摘要
  body: string;                   // 正文（Markdown格式）
  coverUrl: string | null;        // 封面图片URL
  publishedAt: string | null;     // 发布时间
  tags: Array<{ name: string }>;  // 标签列表
};

// 解析封面图片
const cover = resolveCover("article", article.coverUrl);

// 格式化发布日期
const date = article.publishedAt
  ? new Intl.DateTimeFormat("zh-CN", { dateStyle: "medium" }).format(
      new Date(article.publishedAt),
    )
  : "持续更新";
---

<BaseLayout title={`${article.title}｜B-612星球`}>
  <article class="detail-page" data-content-type="article" data-content-id={article.id}>
    <a class="back-link" href="/articles">← 返回文章列表</a>
    <img class="detail-cover" src={cover} alt={`${article.title} 封面图`} />
    <p class="eyebrow">{article.tags[0]?.name ?? "文章"} · {date}</p>
    <h1 data-content-title>{article.title}</h1>
    <p class="detail-lead" data-content-summary>{article.summary}</p>
    <div class="detail-body">
      <MarkdownRenderer client:load content={article.body} />
    </div>
    <AdminDetailEdit client:load type="article" id={article.id} />
    <Comments client:load contentType="article" contentId={article.id} />
  </article>
</BaseLayout>