---
/**
 * 作品列表页面
 * 展示所有项目作品，支持分页浏览
 */
import BaseLayout from "../../layouts/BaseLayout.astro";      // 基础布局
import ProximityHeading from "../../components/ProximityHeading"; // 邻近效应标题
import { apiBase } from "../../lib/api";                        // API配置
import { resolveCover } from "../../lib/defaultCovers";        // 封面解析工具

/** 作品类型 */
type Project = {
  id: string;                     // 作品ID
  slug: string;                   // 短链接
  title: string;                  // 标题
  summary: string;                // 摘要
  coverUrl: string | null;        // 封面图片URL
  stack: string | null;           // 技术栈
  tags: Array<{ name: string }>;  // 标签列表
};

// 数据初始化
let projects: Project[] = [];  // 作品列表
let loadError = false;         // 加载错误标志

// SSR期间获取作品数据
try {
  const response = await fetch(`${apiBase}/projects`);
  if (!response.ok) throw new Error("Unable to load projects");
  projects = await response.json();
} catch {
  loadError = true;
}

// 分页配置
const pageSize = 6;                                                                 // 每页条数
const requestedPage = Number(Astro.url.searchParams.get("page") ?? "1");             // 请求的页码
const totalPages = Math.max(1, Math.ceil(projects.length / pageSize));              // 总页数
const currentPage = Number.isFinite(requestedPage) ? Math.min(Math.max(1, Math.trunc(requestedPage)), totalPages) : 1; // 当前页码（安全处理）
const pagedProjects = projects.slice((currentPage - 1) * pageSize, currentPage * pageSize); // 当前页作品
const pageNumbers = Array.from({ length: totalPages }, (_, index) => index + 1);    // 页码数组
---

<BaseLayout title="作品｜B-612星球">
  <section class="section standalone-page">
    <div class="section-heading">
      <div>
        <p class="eyebrow">SELECTED WORK</p>
        <h2><ProximityHeading client:load label="正在生长的作品" /></h2>
      </div>
      <a class="text-button" href="/contact">一起合作 ↗</a>
    </div>

    {
      loadError ? (
        <p class="empty">作品暂时无法加载，请确认后端服务已经启动。</p>
      ) : projects.length ? (
        <>
          <div class="project-grid">
            {pagedProjects.map((project, index) => {
              const coverIndex = (currentPage - 1) * pageSize + index;
              return (
                <a
                  class={`project-card project-${(index % 2) + 1} reveal-link`}
                  href={`/projects/${project.slug}`}
                >
                  <img
                    class="content-cover-thumb"
                    src={resolveCover("project", project.coverUrl, coverIndex)}
                    alt={`${project.title} 封面图`}
                    loading="lazy"
                  />
                  <p>{project.tags[0]?.name ?? "项目作品"}</p>
                  <h3>{project.title}</h3>
                  <p>{project.summary}</p>
                  <span>{project.stack ?? "持续迭代中"}</span>
                </a>
              );
            })}
          </div>
          {totalPages > 1 && (
            <nav class="pagination" aria-label="作品分页">
              <a class={currentPage === 1 ? "disabled" : ""} href={currentPage === 1 ? undefined : "/projects?page=1"}>第一页</a>
              <a class={currentPage === 1 ? "disabled" : ""} href={currentPage === 1 ? undefined : `/projects?page=${currentPage - 1}`}>上一页</a>
              {pageNumbers.map((page) => (
                <a class={page === currentPage ? "active" : ""} href={`/projects?page=${page}`} aria-current={page === currentPage ? "page" : undefined}>
                  {page}
                </a>
              ))}
              <a class={currentPage === totalPages ? "disabled" : ""} href={currentPage === totalPages ? undefined : `/projects?page=${currentPage + 1}`}>下一页</a>
              <a class={currentPage === totalPages ? "disabled" : ""} href={currentPage === totalPages ? undefined : `/projects?page=${totalPages}`}>最后一页</a>
            </nav>
          )}
        </>
      ) : (
        <p class="empty">暂时还没有已发布的作品。</p>
      )
    }

    <div class="detail-block">
      <p class="eyebrow">HOW I BUILD</p>
      <div class="process-grid">
        <article>
          <span>01</span>
          <h3>发现问题</h3>
          <p>从真实使用场景开始，而不是从功能列表开始。</p>
        </article>
        <article>
          <span>02</span>
          <h3>设计路径</h3>
          <p>将内容、交互和视觉组织为连贯体验。</p>
        </article>
        <article>
          <span>03</span>
          <h3>快速迭代</h3>
          <p>通过可运行的原型不断验证与完善。</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>