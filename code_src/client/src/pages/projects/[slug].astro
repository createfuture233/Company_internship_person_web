---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import Comments from "../../components/Comments";
import AdminDetailEdit from "../../components/AdminDetailEdit";
import MarkdownRenderer from "../../components/MarkdownRenderer";
import { apiBase } from "../../lib/api";

const { slug } = Astro.params;
const response = slug
  ? await fetch(`${apiBase}/content/project/${encodeURIComponent(slug)}`)
  : null;
if (!response?.ok) return Astro.redirect("/projects");
const project = (await response.json()) as {
  id: string;
  title: string;
  summary: string;
  body: string;
  stack: string | null;
  tags: Array<{ name: string }>;
};
---

<BaseLayout title={`${project.title}｜个人星球`}>
  <article class="detail-page detail-reveal" data-content-type="project" data-content-id={project.id}>
    <a class="back-link" href="/projects">← 返回作品列表</a>
    <p class="eyebrow">{project.tags[0]?.name ?? "项目作品"}</p>
    <h1 data-content-title>{project.title}</h1>
    <p class="detail-lead" data-content-summary>{project.summary}</p>
    <div class="detail-body">
      <h2>项目内容</h2>
      <MarkdownRenderer client:load content={project.body} />
      <div class="detail-spec">
        <span>技术栈</span><strong>{project.stack ?? "持续迭代中"}</strong><span
          >状态</span
        ><strong>持续迭代中</strong>
      </div>
    </div>
    <AdminDetailEdit client:load type="project" id={project.id} />
    <Comments client:load contentType="project" contentId={project.id} />
  </article>
</BaseLayout>