---
/**
 * 首页组件
 * 展示网站概览，包括统计数据、最新内容和导航入口
 */
import BaseLayout from "../layouts/BaseLayout.astro";      // 基础布局
import ProximityHeading from "../components/ProximityHeading"; // 邻近效应标题
import AdminPlanetLogin from "../components/AdminPlanetLogin"; // 管理员登录入口
import { apiBase } from "../lib/api";                        // API配置

/** 标签类型 */
type Tag = { name: string };

/** 内容项类型 */
type ContentItem = {
  id: string;                           // 内容ID
  slug?: string | null;                 // 短链接（作品用）
  type: "article" | "project";          // 类型（文章或作品）
  title: string;                        // 标题
  summary: string;                      // 摘要
  stack?: string | null;                // 技术栈（作品用）
  publishedAt?: string | null;          // 发布时间
  tags?: Tag[];                         // 标签列表
  _count?: { comments?: number };       // 评论数量
};

// 数据初始化
let articles: ContentItem[] = [];  // 文章列表
let projects: ContentItem[] = [];  // 作品列表
let loadError = false;             // 加载错误标志

// SSR期间获取数据
try {
  const [articleResponse, projectResponse] = await Promise.all([
    fetch(`${apiBase}/articles`),
    fetch(`${apiBase}/projects`),
  ]);

  if (!articleResponse.ok || !projectResponse.ok) {
    throw new Error("Unable to load home statistics");
  }

  articles = await articleResponse.json();
  projects = await projectResponse.json();
} catch {
  loadError = true;
}

// 计算衍生数据
const allContent = [...articles, ...projects];                               // 所有内容
const totalComments = allContent.reduce((sum, item) => sum + (item._count?.comments ?? 0), 0); // 总评论数
const tagNames = Array.from(new Set(allContent.flatMap((item) => item.tags?.map((tag) => tag.name) ?? []))); // 所有标签
const latestArticle = articles[0];                                          // 最新文章
const latestProject = projects[0];                                          // 最新作品
const latestContent = allContent.filter((item) => item.publishedAt).sort((a, b) => new Date(b.publishedAt ?? 0).getTime() - new Date(a.publishedAt ?? 0).getTime())[0]; // 最新内容

// 工具函数

/**
 * 数字转两位字符串
 * @param value - 数字
 * @returns 两位字符串（如 5 -> "05"）
 */
const twoDigits = (value: number) =>
  value === 0 ? "00" : String(value).padStart(2, "0");

/**
 * 获取简短文本（空值时使用默认值）
 * @param value - 文本值
 * @param fallback - 默认值
 * @returns 处理后的文本
 */
const shortText = (value: string | undefined | null, fallback: string) =>
  value && value.trim().length > 0 ? value.trim() : fallback;

/**
 * 格式化日期为中文短格式
 * @param value - ISO日期字符串
 * @returns 格式化的日期（如 "7月24日"）
 */
const formatDate = (value?: string | null) =>
  value
    ? new Intl.DateTimeFormat("zh-CN", {
        month: "short",
        day: "numeric",
      }).format(new Date(value))
    : "持续更新";
---

<BaseLayout>
  <section class="hero">
    <div class="orb orb-one"></div>
    <div class="orb orb-two"></div>
    <div class="hero-copy">
      <p class="eyebrow">WELCOME TO MY LITTLE PLANET</p>
      <h1>
        <ProximityHeading client:load label="把生活的灵感 画进数字宇宙。" />
      </h1>
      <p class="lead">
        你好，我是一名持续探索设计、代码与表达的人。这里收集我的作品、文章，以及尚未完成的想法。
      </p>
      <a class="primary-button" href="/articles">开始漫游 ↓</a>
    </div>
    <div class="hero-art">
      <AdminPlanetLogin client:load />
      <div class="planet">
        <i></i><i></i><i></i>
      </div>
      <div class="orbit"><b>✦</b></div>
      <p>
        2026<br />PERSONAL<br />PLANET
      </p>
    </div>
  </section>

  <section class="content-band">
    <p class="eyebrow">TRANSMISSION LOG</p>
    <h2>
      <ProximityHeading client:load label="这个星球，正在缓慢生长。" />
    </h2>
    <p>
      {loadError
        ? "数据库信号暂时没有连接成功，下面先显示默认占位；启动后端后会自动读取最新内容。"
        : `目前已公开 ${articles.length} 篇文章、${projects.length} 个作品，累计收到 ${totalComments} 条评论信号。`}
    </p>

    <div class="stat-grid home-stat-grid">
      <a class="home-stat-card" href="/articles">
        <small>ARCHIVE / 01</small>
        <strong>{twoDigits(articles.length)}</strong>
        <span>已发布文章</span>
        <p>
          最近一篇：{shortText(latestArticle?.title, "等待下一篇记录")}
        </p>
        <em>{latestArticle ? formatDate(latestArticle.publishedAt) : "持续写作"}</em>
      </a>

      <a class="home-stat-card" href="/projects">
        <small>BUILDING / 02</small>
        <strong>{twoDigits(projects.length)}</strong>
        <span>已发布作品</span>
        <p>
          最新作品：{shortText(latestProject?.title, "正在准备新的作品")}
        </p>
        <em>{latestProject?.stack ?? "技术栈持续扩展"}</em>
      </a>

      <a
        class="home-stat-card"
        href={latestContent?.type === "project"
          ? `/projects/${latestContent.slug ?? latestContent.id}`
          : latestContent
            ? `/articles/${latestContent.id}`
            : "/about"}
      >
        <small>SIGNAL / 03</small>
        <strong>{tagNames.length || "∞"}</strong>
        <span>内容标签与灵感</span>
        <p>
          {tagNames.length
            ? `正在围绕 ${tagNames.slice(0, 3).join(" / ")} 等方向更新。`
            : "等待更多主题被点亮。"}
        </p>
        <em>{totalComments} 条评论 · {allContent.length} 个公开内容</em>
      </a>
    </div>
  </section>

  <section class="content-band home-links">
    <p class="eyebrow">EXPLORE NEXT</p>
    <div class="explore-grid">
      <a href="/about">
        <span>01</span>
        <h3>认识我</h3>
        <p>关于经历、技能与正在探索的方向。</p>
        <b>↗</b>
      </a>
      <a href="/projects">
        <span>02</span>
        <h3>查看作品</h3>
        <p>从想法到界面的实践记录。</p>
        <b>↗</b>
      </a>
    </div>
  </section>
</BaseLayout>