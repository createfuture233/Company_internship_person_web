---
import '../styles/global.css'
import Navigation from '../components/Navigation'
import Footer from '../components/Footer'
import VisitorAiDock from '../components/VisitorAiDock'
const { title = '个人星球', description = '个人星球：记录作品、思考与成长。' } = Astro.props
---
<!doctype html>
<html lang="zh-CN" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fff8eb" />
    <link rel="icon" type="image/svg+xml" href="/assets/icons/personal-planet-favicon.svg" />
    <link rel="manifest" href="/assets/icons/site.webmanifest" />
    <title>{title}</title>
  </head>
  <body>
    <Navigation client:load />
    <main><slot /></main>
    <VisitorAiDock client:load />
    <Footer client:load />
    <button class="back-to-top" type="button" aria-label="Back to top" data-back-to-top><span>↑</span><i></i></button>
    <script>
      const savedTheme = localStorage.getItem('personal-planet-theme')
      if (savedTheme === 'dark' || savedTheme === 'light') document.documentElement.dataset.theme = savedTheme
      document.addEventListener('click', (event) => {
        const link = (event.target as Element).closest<HTMLAnchorElement>('.reveal-link')
        if (link) sessionStorage.setItem('reveal-origin', JSON.stringify({ x: event.clientX, y: event.clientY }))
      })
      document.addEventListener('click', (event) => {
        const toggle = (event.target as Element).closest<HTMLElement>('[data-theme-toggle]')
        if (!toggle) return
        const theme = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark'
        document.documentElement.dataset.theme = theme
        localStorage.setItem('personal-planet-theme', theme)
      })
      const detail = document.querySelector<HTMLElement>('.detail-reveal')
      const origin = sessionStorage.getItem('reveal-origin')
      if (detail && origin) {
        const { x, y } = JSON.parse(origin)
        detail.style.setProperty('--reveal-x', `${x}px`)
        detail.style.setProperty('--reveal-y', `${y}px`)
        sessionStorage.removeItem('reveal-origin')
      }
      {
        const revealSelector = [
          'main section > *',
          'main .detail-page > *',
          'main .detail-body > *',
          'main .page-contact > *',
          'main form > *',
          'main .article-grid > *',
          'main .project-grid > *',
          'main .explore-grid > *',
          'main .stats-grid > *',
          'main .timeline > *',
          'main .topic-grid > *',
          'main .detail-block > *',
          'main .two-column > *',
          'main .process-grid > *',
          'main .skill-list > *'
        ].join(', ')
        const revealItems = [...document.querySelectorAll<HTMLElement>(revealSelector)]
        revealItems.forEach((item, index) => {
          item.classList.add('scroll-reveal')
          item.style.setProperty('--scroll-reveal-delay', `${(index % 5) * 70}ms`)
        })
        const playRevealOnce = Boolean(document.querySelector('.detail-page'))
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            const target = entry.target as HTMLElement
            if (entry.isIntersecting) {
              target.classList.add('is-visible')
              if (playRevealOnce) observer.unobserve(target)
            } else if (!playRevealOnce) {
              target.classList.remove('is-visible')
            }
          })
        }, { threshold: .12, rootMargin: '0px 0px -4% 0px' })
        revealItems.forEach((item) => observer.observe(item))
      }
      const tiltCards = document.querySelectorAll<HTMLElement>('.stat-grid > div, .explore-grid > a, .article-card, .project-card, .timeline article, .process-grid article, .about-panel, .topic-grid span')
      tiltCards.forEach((card) => {
        card.addEventListener('pointermove', (event) => {
          const rect = card.getBoundingClientRect()
          const x = (event.clientX - rect.left) / rect.width
          const y = (event.clientY - rect.top) / rect.height
          card.style.setProperty('--card-tilt-x', `${(0.5 - y) * 6}deg`)
          card.style.setProperty('--card-tilt-y', `${(x - 0.5) * 7}deg`)
          card.style.setProperty('--card-glow-x', `${x * 100}%`)
          card.style.setProperty('--card-glow-y', `${y * 100}%`)
        })
        card.addEventListener('pointerleave', () => {
          card.style.setProperty('--card-tilt-x', '0deg')
          card.style.setProperty('--card-tilt-y', '0deg')
          card.style.setProperty('--card-glow-x', '50%')
          card.style.setProperty('--card-glow-y', '0%')
        })
      })
      const backToTop = document.querySelector<HTMLButtonElement>('[data-back-to-top]')
      const syncBackToTop = () => backToTop?.classList.toggle('is-visible', window.scrollY > 280)
      window.addEventListener('scroll', syncBackToTop, { passive: true })
      syncBackToTop()
      backToTop?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }))
      const currentPath = window.location.pathname.replace(/\/$/, '') || '/'
      document.querySelectorAll<HTMLAnchorElement>('.nav .links a').forEach((link) => {
        const linkPath = link.pathname.replace(/\/$/, '') || '/'
        const isCurrent = linkPath === '/admin' ? currentPath === '/admin' || currentPath.startsWith('/admin/') : linkPath === currentPath
        link.classList.toggle('active', isCurrent)
        if (isCurrent) link.setAttribute('aria-current', 'page')
        else link.removeAttribute('aria-current')
      })    </script>
  </body>
</html>
