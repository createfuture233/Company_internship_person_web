# ========== 数据库配置 ==========
DATABASE_URL="file:../data/personal-planet.db"

# ========== 管理员配置 ==========
ADMIN_INITIAL_PASSWORD="change-this-before-production"

# ========== AI 配置（可选，不填则 AI 助手不启用） ==========
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-v4-flash"
AI_MAX_CONTEXT_CHARS="12000"
AI_VISITOR_RATE_LIMIT="20"
AI_ADMIN_RATE_LIMIT="100"

# ========== 服务端部署配置 ==========
# 服务监听端口
PORT=3000
# 服务监听地址，0.0.0.0 表示允许所有网络访问
HOST=0.0.0.0
# 允许的 CORS 来源，多个用逗号分隔，支持正则（用 /包裹/）
# 示例：CORS_ORIGINS="https://your-domain.com,https://www.your-domain.com,/\.your-domain\.com$/"
CORS_ORIGINS=""

# ========== 前端环境变量（构建时注入） ==========
# 后端 API 的完整地址（浏览器端访问的 URL）
# 本地开发：http://localhost:3000/api
# 同域名部署：/api
# 跨域名部署：https://api.your-domain.com/api
PUBLIC_API_BASE="/api"

# ========== 上传文件配置 ==========
# 线上推荐使用项目根目录下的 uploads，配合 Nginx 的 /uploads/ 静态映射。
# 示例：/var/www/Company_internship_person_web/uploads
UPLOAD_ROOT=""
