generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ContentType {
  article
  project
}

enum ContentStatus {
  draft
  published
  archived
}

enum CommentStatus {
  visible
  hidden
  spam
}

enum AiRoleScope {
  visitor
  admin
}

enum AiMessageSender {
  user
  assistant
  system
}

enum AiFileParseStatus {
  pending
  success
  failed
}

enum AiGenerationType {
  article
  project
  analysis
  rewrite
}

enum AiGenerationStatus {
  pending
  success
  failed
  saved
}

model Admin {
  id           Int            @id @default(autoincrement())
  username     String         @unique
  passwordHash String         @map("password_hash")
  role         String         @default("admin")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  sessions     AdminSession[]
  auditLogs    AuditLog[]

  @@map("admins")
}

model AdminSession {
  id        Int       @id @default(autoincrement())
  adminId   Int       @map("admin_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  admin     Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([expiresAt])
  @@map("admin_sessions")
}

model Content {
  id          String        @id @default(cuid())
  type        ContentType
  slug        String        @unique
  title       String
  summary     String
  body        String
  coverUrl    String?       @map("cover_url")
  stack       String?
  status      ContentStatus @default(draft)
  publishedAt DateTime?     @map("published_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  tags        ContentTag[]
  comments    Comment[]

  @@index([type, status, publishedAt])
  @@index([updatedAt])
  @@map("contents")
}

model ContentTag {
  id        Int     @id @default(autoincrement())
  contentId String  @map("content_id")
  name      String
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([contentId, name])
  @@index([name])
  @@map("content_tags")
}

model Comment {
  id         String        @id @default(cuid())
  contentId  String        @map("content_id")
  nickname   String
  avatarText String        @map("avatar_text")
  body       String
  likes      Int           @default(0)
  status     CommentStatus @default(visible)
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  content    Content       @relation(fields: [contentId], references: [id], onDelete: Cascade)
  likedBy    CommentLike[]

  @@index([contentId, createdAt])
  @@index([contentId, likes])
  @@index([status])
  @@map("comments")
}

model CommentLike {
  id         Int      @id @default(autoincrement())
  commentId  String   @map("comment_id")
  visitorKey String   @map("visitor_key")
  createdAt  DateTime @default(now()) @map("created_at")
  comment    Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, visitorKey])
  @@index([visitorKey])
  @@map("comment_likes")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  status    String   @default("unread")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@index([email])
  @@map("contact_messages")
}

model Subscription {
  id          Int       @id @default(autoincrement())
  email       String    @unique
  confirmedAt DateTime? @map("confirmed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("subscriptions")
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  adminId    Int      @map("admin_id")
  action     String
  targetType String   @map("target_type")
  targetId   String?  @map("target_id")
  payload    String?
  createdAt  DateTime @default(now()) @map("created_at")
  admin      Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

model AiConversation {
  id          String       @id @default(cuid())
  roleScope   AiRoleScope  @map("role_scope")
  contentId   String?      @map("content_id")
  contentType ContentType? @map("content_type")
  title       String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  messages    AiMessage[]

  @@index([roleScope, updatedAt])
  @@index([contentType, contentId])
  @@map("ai_conversations")
}

model AiMessage {
  id             String          @id @default(cuid())
  conversationId String          @map("conversation_id")
  sender         AiMessageSender
  body           String
  tokenUsage     Int?            @map("token_usage")
  createdAt      DateTime        @default(now()) @map("created_at")
  conversation   AiConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("ai_messages")
}

model AiUploadedFile {
  id           String            @id @default(cuid())
  originalName String            @map("original_name")
  mimeType     String            @map("mime_type")
  fileSize     Int               @map("file_size")
  storagePath  String            @map("storage_path")
  parsedText   String            @map("parsed_text")
  parseStatus  AiFileParseStatus @default(pending) @map("parse_status")
  errorMessage String?           @map("error_message")
  createdAt    DateTime          @default(now()) @map("created_at")
  generations  AiGeneration[]

  @@index([parseStatus, createdAt])
  @@map("ai_uploaded_files")
}

model AiGeneration {
  id              String             @id @default(cuid())
  generationType  AiGenerationType   @map("generation_type")
  sourceFileId    String?            @map("source_file_id")
  sourceContentId String?            @map("source_content_id")
  prompt          String
  resultJson      String             @map("result_json")
  targetContentId String?            @map("target_content_id")
  status          AiGenerationStatus @default(pending)
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  sourceFile      AiUploadedFile?    @relation(fields: [sourceFileId], references: [id], onDelete: SetNull)

  @@index([generationType, status, createdAt])
  @@index([sourceContentId])
  @@index([targetContentId])
  @@map("ai_generations")
}
